# .env.example
# Copy this to .env and fill in any values you need.
# The app runs fully offline — no keys are required for local use.

# ── Model cache ───────────────────────────────────────────────────────────────
# Override the Hugging Face cache location (useful if your home drive is small)
# HF_HOME=/data/hf_cache

# ── Performance ───────────────────────────────────────────────────────────────
# Avoid a deadlock warning when tokenizers run inside forked processes
TOKENIZERS_PARALLELISM=false

# Limit the number of CPU threads PyTorch may use
# OMP_NUM_THREADS=4

# ── Index persistence ─────────────────────────────────────────────────────────
# Default directory used by the Save / Load buttons in the sidebar
# FAISS_INDEX_DIR=./saved_index

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION UPGRADE PATH (optional, all free tiers available)
# ─────────────────────────────────────────────────────────────────────────────
#
# To move beyond a local demo to a hosted production service, swap these
# components (all have free tiers):
#
#  Vector store  │ FAISS (local)  →  Qdrant Cloud (1 GB free) or Pinecone (free)
#  LLM           │ flan-t5-base   →  Groq API (free, fast) or Claude API
#  Hosting       │ local          →  Streamlit Community Cloud, Hugging Face Spaces,
#                │                   Railway, or Render (all have free tiers)
#  Document store│ in-memory      →  AWS S3, GCS, or Azure Blob for uploaded files
#
# Uncomment and set the relevant keys once you have added the matching adapters:
#
# GROQ_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY = <your_openai_api_key>
# QDRANT_URL=
# QDRANT_API_KEY=
# PINECONE_API_KEY=
# PINECONE_INDEX=
